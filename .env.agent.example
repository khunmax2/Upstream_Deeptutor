# In-page agent loop — LLM config, SEPARATE from DeepTutor's chat model.
# See deeptutor/services/voice_realtime/agent/llm.py
#
# Usage:
#   cp .env.agent.example .env.agent   # the real file — gitignored, never committed
#   # fill in the values below in .env.agent
#   set -a && source .env.agent && set +a
#   deeptutor start

# Required — turns the loop on. Voice behaves exactly as before while unset/0.
DEEPTUTOR_AGENT_LOOP=1

# Required — must be a FULL-tier model, not a "lite" one. The agent loop feeds
# an indexed DOM snapshot into the prompt and tool-calls for up to 15 steps;
# a lite tier was observed to behave erratically under that load.
# (The 2.5 family is retired for new accounts; use a current flash model.)
DEEPTUTOR_AGENT_MODEL=gemini-flash-latest

# Optional — set BOTH together to bypass DeepTutor's chat LLM catalog entirely
# and call this OpenAI-compatible endpoint directly (independent provider/key).
# Leave both blank to reuse DeepTutor's configured provider + key, with only
# the model above overridden.
DEEPTUTOR_AGENT_BASE_URL=
DEEPTUTOR_AGENT_API_KEY=

# Optional — force the provider spec by name for an OpenAI-compatible upstream so
# the ENDPOINT decides the provider, not the model name. Needed on hosts where
# model-name inference misroutes: e.g. Groq with `qwen/*` otherwise resolves to
# the dashscope provider and injects params Groq rejects (400). Set `openai` for
# generic OpenAI-compat hosts. Leave blank for Gemini/known gateways (unchanged).
DEEPTUTOR_AGENT_BINDING=

# Optional loop tuning — leave blank to keep the built-in defaults (settle delay
# 0.8s, max 15 steps). The default delay is conservative for animation-heavy
# DOMs; on light pages you can trim latency by lowering it toward page-agent's
# 0.4. Invalid/negative values are ignored (defaults kept).
DEEPTUTOR_AGENT_STEP_DELAY=
DEEPTUTOR_AGENT_MAX_STEPS=

# ── Voice intent classifier (optional, off by default) ──
# The primary semantic router: decides chat vs a UI command and hands UI tasks
# to the loop, so "สร้างหนังสือใหม่" (create book) completes instead of half-
# navigating. See deeptutor/services/voice_realtime/intent_classifier.py and
# docs/issues/voice-intent-classifier/. Classification is EASY, so a cheap LITE
# model is ideal here (unlike the loop above). Needs the loop enabled too.
DEEPTUTOR_VOICE_CLASSIFIER=0
DEEPTUTOR_VOICE_CLASSIFIER_MODEL=gemini-flash-lite-latest
# Optional standalone upstream for the classifier (same shape as the agent's):
DEEPTUTOR_VOICE_CLASSIFIER_BASE_URL=
DEEPTUTOR_VOICE_CLASSIFIER_API_KEY=
# Force the provider spec by name (see DEEPTUTOR_AGENT_BINDING). Blank ⇒ inferred.
DEEPTUTOR_VOICE_CLASSIFIER_BINDING=
