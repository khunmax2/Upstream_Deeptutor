# Standalone OpenAI-compatible upstream for the in-page agent (page-agent eval).
#
# Set ALL THREE to bypass DeepTutor's LLM catalog entirely — the proxy then
# talks straight to this endpoint. The browser never sees any of it, and cannot
# choose the model. Leave all three unset to fall back to the app's chat model.
#
# Reference: the suanrao project runs page-agent on gemini-2.5-flash and it
# behaves well; this app's chat model is a -lite tier, which is the leading
# suspect for page-agent behaving erratically here.
#
# Usage:  set -a && source .env.llm-proxy && set +a && deeptutor start

LLM_PROXY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_PROXY_API_KEY=
LLM_PROXY_MODEL=gemini-2.5-flash
