# ── OpenRouter preset — put your key in ONE place ──────────────────────────
# Copy to .env, fill OPENROUTER_API_KEY, then:  set -a; source .env; set +a
# It feeds LLM + STT + TTS below (any slot whose own *_API_KEY is left blank).

OPENROUTER_API_KEY=             # ⟵ ใส่ OpenRouter key ตรงนี้ที่เดียว

# ── brain (LLM) ── use gemini via OpenRouter, OR point at your DeepTutor wrap
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-3.1-flash-lite
# (to use DeepTutor instead: LLM_BASE_URL=http://localhost:8001/v1  LLM_MODEL=deeptutor
#  and set LLM_API_KEY separately)

# ── STT ── gpt-audio-mini does transcription (OpenRouter base64 JSON shape)
STT_BACKEND=openrouter
STT_BASE_URL=https://openrouter.ai/api/v1
STT_MODEL=openai/gpt-audio-mini
STT_LANGUAGE=th

# ── TTS ── gpt-audio-mini also synthesizes speech (/audio/speech, OpenAI-style)
TTS_BACKEND=openai
TTS_OPENAI_BASE_URL=https://openrouter.ai/api/v1
TTS_OPENAI_MODEL=openai/gpt-audio-mini
TTS_OPENAI_VOICE=alloy         # gpt-audio voices: alloy, echo, shimmer, ...

# ── server ──
HOST=127.0.0.1
PORT=8800
CHUNK_MAX_CHARS=120
