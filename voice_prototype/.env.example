# ── LLM: point at your DeepTutor OpenAI-compatible wrap ──
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=sk-local
LLM_MODEL=deeptutor

# ── STT: Groq Whisper (batch-on-endpoint) ──
GROQ_API_KEY=
STT_MODEL=whisper-large-v3
STT_LANGUAGE=th

# ── TTS: choose one backend ──
TTS_BACKEND=openai            # openai | elevenlabs | botnoi

# openai-compatible /audio/speech (OpenAI, or a local TTS server)
TTS_OPENAI_BASE_URL=https://api.openai.com/v1
TTS_OPENAI_API_KEY=
TTS_OPENAI_MODEL=gpt-4o-mini-tts
TTS_OPENAI_VOICE=alloy

# elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# botnoi (verify fields against current BOTNOI Voice docs)
BOTNOI_TOKEN=
BOTNOI_SPEAKER=1

# ── server ──
HOST=127.0.0.1
PORT=8800
CHUNK_MAX_CHARS=120
